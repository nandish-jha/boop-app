<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.SilentOrder.Brand" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.12</item>
    </style>

    <style name="TextAppearance.SilentOrder.Kicker" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/outline</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="TextAppearance.SilentOrder.Display" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="Widget.SilentOrder.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_low</item>
        <item name="cardCornerRadius">@dimen/card_corner</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>
</resources>
