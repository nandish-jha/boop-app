<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_root"
    style="@style/Widget.SilentOrder.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/accent_left"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="@color/primary"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/text_tag"
                style="@style/TextAppearance.Material3.LabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:textColor="@color/outline"
                android:visibility="gone"
                tools:text="PRIMARY" />

            <TextView
                android:id="@+id/text_account_title"
                style="@style/TextAppearance.Material3.TitleSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textStyle="bold"
                tools:text="CHECKING" />

            <TextView
                android:id="@+id/text_account_sub"
                style="@style/TextAppearance.Material3.BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/on_surface_variant"
                tools:text="Scotiabank · chequing" />

            <TextView
                android:id="@+id/text_account_balance"
                style="@style/TextAppearance.Material3.HeadlineSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                tools:text="$12,450.00" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
