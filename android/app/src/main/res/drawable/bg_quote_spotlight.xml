<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_low" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.5"
                android:centerY="0"
                android:endColor="#001A1A1A"
                android:gradientRadius="280dp"
                android:startColor="#22FFFFFF"
                android:type="radial" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
