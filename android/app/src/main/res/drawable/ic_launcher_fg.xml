<?xml version="1.0" encoding="utf-8"?>
<!--
    ProDash minimal "P" mark.
    Adaptive icon canvas is 108x108dp. Safe zone is central 66dp.
    The letter is centered inside the safe zone so it renders correctly on
    round, squircle and Material You themed shapes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Stem: full cap-height rounded bar (x 38..50, y 34..74) -->
    <path
        android:pathData="M38,34 L50,34 L50,74 L38,74 Z"
        android:fillColor="#F5F5F5"/>
    <!-- Stem rounded caps via circles -->
    <path
        android:pathData="M44,34 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0"
        android:fillColor="#F5F5F5"/>
    <path
        android:pathData="M44,74 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0"
        android:fillColor="#F5F5F5"/>

    <!-- Bowl: rounded-rect top-right of stem (x 38..76, y 34..58) -->
    <path
        android:pathData="M38,34 h26 a12,12 0 0 1 12,12 v0 a12,12 0 0 1 -12,12 h-26 Z"
        android:fillColor="#F5F5F5"/>
    <!-- Bowl inner cutout (hole) -->
    <path
        android:pathData="M50,40 h14 a6,6 0 0 1 6,6 v0 a6,6 0 0 1 -6,6 h-14 Z"
        android:fillColor="#121212"/>
</vector>
